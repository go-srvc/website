<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<meta name="description" content="{{.Description}}">
	<title>{{.Title}}</title>
	<script>(function(){try{var t=localStorage.getItem('go-srvc-theme');if(t)document.documentElement.setAttribute('data-theme',t);}catch(e){}})();</script>
	<link rel="stylesheet" href="{{.RelPrefix}}assets/css/main.css">
	<link rel="stylesheet" href="{{.RelPrefix}}assets/css/themes.css">
	<link rel="stylesheet" href="{{.RelPrefix}}assets/css/anim.css">
	<script src="{{.RelPrefix}}assets/js/lifecycle.js" defer></script>
	<script src="{{.RelPrefix}}assets/js/theme.js" defer></script>
</head>
<body>
<header class="site-header">
	<a class="brand" href="{{.RelPrefix}}">go-srvc</a>
	<nav>
		<a href="https://github.com/go-srvc/srvc">srvc</a>
		<a href="https://github.com/go-srvc/mods">mods</a>
		<a href="https://pkg.go.dev/github.com/go-srvc/srvc">godoc</a>
		<a href="https://github.com/go-srvc">GitHub</a>
	</nav>
</header>
<div class="layout">
	<aside class="sidebar">
		<nav aria-label="Packages">
			<ul class="tree">
				{{range .Sidebar}}
				<li class="section{{if .IsActive}} active{{end}}">
					<a href="{{.URL}}">{{.Label}}</a>
					{{if .Items}}
					<ul>
						{{range .Items}}
						<li{{if .IsActive}} class="active"{{end}}><a href="{{.URL}}">{{.Slug}}</a></li>
						{{end}}
					</ul>
					{{end}}
				</li>
				{{end}}
			</ul>
		</nav>
		<div class="theme-picker">
			<label for="theme-select">Theme</label>
			<select id="theme-select">
				<option value="sky">Sky</option>
				<option value="forest">Forest</option>
				<option value="sunset">Sunset</option>
				<option value="mono">Mono</option>
				<option value="nord">Nord</option>
				<option value="solarized">Solarized</option>
				<option value="dracula">Dracula (dark)</option>
				<option value="catppuccin">Catppuccin</option>
			</select>
		</div>
	</aside>
	<main>
{{template "content" .}}
	</main>
</div>
<footer class="site-footer">
	<p>Apache 2.0 · <a href="https://github.com/go-srvc">github.com/go-srvc</a></p>
</footer>
</body>
</html>
