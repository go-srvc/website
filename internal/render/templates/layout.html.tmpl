<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<meta name="description" content="{{.Description}}">
	<title>{{.Title}}</title>
	<link rel="canonical" href="{{.CanonicalURL}}">
	<meta property="og:type" content="website">
	<meta property="og:site_name" content="go-srvc">
	<meta property="og:title" content="{{.Title}}">
	<meta property="og:description" content="{{.Description}}">
	<meta property="og:url" content="{{.CanonicalURL}}">
	<meta name="twitter:card" content="summary">
	<meta name="twitter:title" content="{{.Title}}">
	<meta name="twitter:description" content="{{.Description}}">
	<link rel="stylesheet" href="{{.RelPrefix}}assets/css/main.css">
	<link rel="stylesheet" href="{{.RelPrefix}}assets/css/anim.css">
	<link rel="stylesheet" href="{{.RelPrefix}}assets/css/syntax.css">
	<script src="{{.RelPrefix}}assets/js/lifecycle.js" defer></script>
</head>
<body>
<header class="site-header">
	<a class="brand" href="{{.RelPrefix}}">go-srvc</a>
	<nav>
		<a href="https://github.com/go-srvc/srvc">srvc</a>
		<a href="https://github.com/go-srvc/mods">mods</a>
		<a href="https://pkg.go.dev/github.com/go-srvc/srvc">godoc</a>
		<a href="https://github.com/go-srvc">GitHub</a>
	</nav>
</header>
<div class="layout">
	<aside class="sidebar">
		<nav aria-label="Packages">
			<ul class="tree">
				{{range .Sidebar}}
				<li class="section{{if .IsActive}} active{{end}}">
					<a href="{{.URL}}">{{.Label}}</a>
					{{if .Items}}
					<ul>
						{{range .Items}}
						<li{{if .IsActive}} class="active"{{end}}><a href="{{.URL}}">{{.Slug}}</a></li>
						{{end}}
					</ul>
					{{end}}
				</li>
				{{end}}
			</ul>
		</nav>
	</aside>
	<main>
{{template "content" .}}
	</main>
</div>
<footer class="site-footer">
	<p>Apache 2.0 · <a href="https://github.com/go-srvc">github.com/go-srvc</a></p>
</footer>
</body>
</html>
