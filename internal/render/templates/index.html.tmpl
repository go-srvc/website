{{define "anim-svg"}}
<svg viewBox="0 0 280 60" aria-hidden="true" role="img">
	<rect class="box m1" x="10" y="10" width="55" height="40" rx="4"/>
	<rect class="box m2" x="75" y="10" width="55" height="40" rx="4"/>
	<rect class="box m3" x="140" y="10" width="55" height="40" rx="4"/>
	<rect class="box m4" x="205" y="10" width="55" height="40" rx="4"/>
	<text class="label" x="37" y="35" text-anchor="middle">M1</text>
	<text class="label" x="102" y="35" text-anchor="middle">M2</text>
	<text class="label" x="167" y="35" text-anchor="middle">M3</text>
	<text class="label" x="232" y="35" text-anchor="middle">M4</text>
</svg>
{{end}}

{{define "content"}}
<section class="hero">
	<h1>Service Runner: Simple Safe Modular</h1>
	<p class="tagline">{{.Description}}</p>
	<pre class="install"><code>go get github.com/go-srvc/srvc@latest</code></pre>
	<p class="hero-links">
		<a class="btn" href="{{.RelPrefix}}srvc/">srvc docs</a>
		<a class="btn btn-secondary" href="{{.RelPrefix}}mods/">mods catalog</a>
	</p>
</section>

<section class="lifecycle">
	<h2>Lifecycle, visualized</h2>
	<p class="lead">Four modules going through srvc's lifecycle under different scenarios. One row plays at a time; hover any row to lock the animation to it.</p>
	<div class="legend" aria-hidden="true">
		<span class="item"><span class="dot"></span>idle</span>
		<span class="item"><span class="dot init"></span>init</span>
		<span class="item"><span class="dot run"></span>run</span>
		<span class="item"><span class="dot stopping"></span>stopping</span>
		<span class="item"><span class="dot stopped"></span>stopped</span>
		<span class="item"><span class="dot error"></span>error</span>
		<span class="item"><span class="dot panic"></span>panic</span>
	</div>

	<div class="anim-list">
		<figure class="anim anim-clean">
			<div class="anim-text">
				<h3>Clean shutdown</h3>
				<p>Signal triggers shutdown. Modules stop in reverse order.</p>
			</div>
			<div class="anim-vis">{{template "anim-svg" .}}</div>
		</figure>
		<figure class="anim anim-init">
			<div class="anim-text">
				<h3>Init error</h3>
				<p>M3's Init fails. M1 and M2, the already-initialised modules, get Stop in reverse. M4 never starts.</p>
			</div>
			<div class="anim-vis">{{template "anim-svg" .}}</div>
		</figure>
		<figure class="anim anim-panic">
			<div class="anim-text">
				<h3>Panic recovery</h3>
				<p>M3 panics during Run. The panic is recovered as an error and the rest shut down gracefully.</p>
			</div>
			<div class="anim-vis">{{template "anim-svg" .}}</div>
		</figure>
		<figure class="anim anim-timeout">
			<div class="anim-text">
				<h3>Stop timeout</h3>
				<p>M3's Stop hangs. <code>StopTimeout</code> fires and Run returns with <code>ErrStopTimeout</code>. Remaining stops never complete.</p>
			</div>
			<div class="anim-vis">{{template "anim-svg" .}}</div>
		</figure>
	</div>
</section>

<section class="example">
	<h2>A practical example</h2>
	<p class="lead">An HTTP server that shuts down cleanly on <code>SIGINT</code>. <code>srvc.Run</code> coordinates the lifecycle of the signal listener and the server. Either module returning ends the run loop, and Stop runs in reverse on the way out.</p>
	<pre class="example-code"><code>package main

import (
	"fmt"
	"net/http"
	"os"

	"github.com/go-srvc/mods/httpmod"
	"github.com/go-srvc/mods/sigmod"
	"github.com/go-srvc/srvc"
)

func main() {
	srvc.RunAndExit(
		sigmod.New(os.Interrupt),
		httpmod.New(
			httpmod.WithAddr(":8080"),
			httpmod.WithHandler(http.HandlerFunc(hello)),
		),
	)
}

func hello(w http.ResponseWriter, r *http.Request) {
	fmt.Fprint(w, "hello, world")
}
</code></pre>
</section>

<section class="cards">
	<article class="card">
		<h2><a href="{{.RelPrefix}}srvc/">srvc</a></h2>
		<p>Package overview, exported API, and runnable examples extracted from the latest tagged release.</p>
		{{if .SrvcVersion}}<p class="card-status"><code>{{.SrvcVersion}}</code></p>{{end}}
	</article>
	<article class="card">
		<h2><a href="{{.RelPrefix}}mods/">Mods catalog</a></h2>
		<p>Ready-made modules for HTTP, SQL, OpenTelemetry, signals, and tickers. Pick a tagged release on each mod's page.</p>
		{{if .ModCount}}<p class="card-status">{{.ModCount}} modules</p>{{end}}
	</article>
</section>
{{end}}
